# Solstead production deploy — copy to .env and fill in before deploy

# Your public domain (no trailing slash)
SOLSTEAD_DOMAIN=https://solstead.xyz

# Game server bind (behind nginx reverse proxy)
AEVEN_BIND_ADDR=0.0.0.0:2567
AEVEN_ENV=production

# Required in production
AEVEN_SESSION_SIGNING_SECRET=change-me-to-at-least-32-random-bytes
AEVEN_ALLOWED_ORIGINS=https://solstead.xyz,https://www.solstead.xyz

# Optional admin panel
# AEVEN_ADMIN_API_TOKEN=

# WASM + site build URLs (used by scripts/deploy-solstead.sh)
AEVEN_SERVER_URL=https://solstead.xyz
AEVEN_WS_URL=wss://solstead.xyz

# SvelteKit site canonical URL
VITE_SITE_URL=https://solstead.xyz

# VPS deploy path
SITE_DEPLOY_DIR=/var/www/solstead
